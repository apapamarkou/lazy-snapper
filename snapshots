set -uo pipefail

# ═══════════════════════════════════════════════════════════════════════════
# CONFIGURATION & COLORS
# ═══════════════════════════════════════════════════════════════════════════

readonly SCRIPT_NAME="System Snapshot Manager"
readonly VERSION="1.0.0"

# Determine if we need sudo for snapper commands
if [ "$EUID" -eq 0 ]; then
    SUDO_CMD=""
else
    SUDO_CMD="sudo"
fi

# ANSI Color Codes
readonly C_RESET='\033[0m'
readonly C_RED='\033[0;31m'
readonly C_GREEN='\033[0;32m'
readonly C_YELLOW='\033[0;33m'
readonly C_BLUE='\033[0;34m'
readonly C_MAGENTA='\033[0;35m'
readonly C_CYAN='\033[0;36m'
readonly C_WHITE='\033[1;37m'
readonly C_BOLD='\033[1m'
readonly C_DIM='\033[2m'

# ═══════════════════════════════════════════════════════════════════════════
# UTILITY FUNCTIONS
# ═══════════════════════════════════════════════════════════════════════════

# Check if required commands are available
check_dependencies() {
    local missing_deps=()
    
    if ! command -v fzf &> /dev/null; then
        missing_deps+=("fzf")
    fi
    
    if ! command -v snapper &> /dev/null; then
        missing_deps+=("snapper")
    fi
    
    if [ ${#missing_deps[@]} -gt 0 ]; then
        echo -e "${C_RED}Error: Missing dependencies: ${missing_deps[*]}${C_RESET}" >&2
        exit 1
    fi
}

# Get Y/N confirmation from user
confirm_action() {
    local prompt="$1"
    local response
    
    echo -e "\n${C_YELLOW}${prompt}${C_RESET}"
    echo -e "${C_CYAN}Press [Y] to confirm, [N] to cancel:${C_RESET}"
    
    while true; do
        read -rsn1 response
        case "$response" in
            [Yy])
                echo -e "${C_GREEN}✓ Confirmed${C_RESET}"
                return 0
                ;;
            [Nn])
                echo -e "${C_RED}✗ Cancelled${C_RESET}"
                return 1
                ;;
        esac
    done
}

# Display error message and wait for keypress
show_error() {
    local message="$1"
    echo -e "\n${C_RED}✗ Error: ${message}${C_RESET}"
    echo -e "${C_DIM}Press any key to continue...${C_RESET}"
    read -rsn1
}

# Display success message and wait for keypress
show_success() {
    local message="$1"
    echo -e "\n${C_GREEN}✓ Success: ${message}${C_RESET}"
    echo -e "${C_DIM}Press any key to continue...${C_RESET}"
    read -rsn1
}

# ═══════════════════════════════════════════════════════════════════════════
# SNAPSHOT OPERATIONS
# ═══════════════════════════════════════════════════════════════════════════

# Format snapshot for fzf display (date-time only)
format_snapshot_list() {
    # Parse snapper list output using table format with │ separators
    $SUDO_CMD snapper list 2>/dev/null | tail -n +3 | grep -v '^───' | grep -v '^[[:space:]]*0[[:space:]]' | awk -F'│' '{
        # Extract fields from table format
        num = $1
        type = $2
        pre = $3
        datetime = $4
        user = $5
        cleanup = $6
        desc = $7
        
        # Clean whitespace
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", num)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", datetime)
        
        # Skip empty datetime (like snapshot 0)
        if (datetime != "") {
            printf "%s | %s\n", num, datetime
        }
    }'
}

# Get detailed preview for a snapshot (standalone for fzf)
get_snapshot_preview() {
    local snap_num="$1"
    
    if [ -z "$snap_num" ]; then
        echo "No snapshot selected"
        return
    fi
    
    # Get snapshot info from table format
    local info=$($SUDO_CMD snapper list 2>/dev/null | grep -E "^[[:space:]]*${snap_num}[[:space:]]*│")
    
    if [ -z "$info" ]; then
        echo "Snapshot not found"
        return
    fi
    
    # Parse fields using │ separator
    local num=$(echo "$info" | awk -F'│' '{print $1}' | xargs)
    local type=$(echo "$info" | awk -F'│' '{print $2}' | xargs)
    local pre=$(echo "$info" | awk -F'│' '{print $3}' | xargs)
    local datetime=$(echo "$info" | awk -F'│' '{print $4}' | xargs)
    local user=$(echo "$info" | awk -F'│' '{print $5}' | xargs)
    local cleanup=$(echo "$info" | awk -F'│' '{print $6}' | xargs)
    local desc=$(echo "$info" | awk -F'│' '{print $7}' | xargs)
    
    # Get space usage (if available)
    local space="N/A"
    if command -v btrfs &> /dev/null; then
        local snap_path="/.snapshots/${snap_num}/snapshot"
        if [ -d "$snap_path" ]; then
            space=$(du -sh "$snap_path" 2>/dev/null | awk '{print $1}' || echo "N/A")
        fi
    fi
    
    # Format preview with colors (inline ANSI codes)
    echo -e "\033[1;36m╔═══════════════════════════════════╗\033[0m"
    echo -e "\033[1;36m║      SNAPSHOT INFORMATION         ║\033[0m"
    echo -e "\033[1;36m╚═══════════════════════════════════╝\033[0m"
    echo ""
    echo -e "\033[0;33mNumber:\033[0m      \033[1;37m${num}\033[0m"
    echo -e "\033[0;33mDate-Time:\033[0m   \033[1;37m${datetime}\033[0m"
    echo -e "\033[0;33mUser:\033[0m        \033[1;37m${user}\033[0m"
    echo -e "\033[0;33mType:\033[0m        \033[1;37m${type}\033[0m"
    echo -e "\033[0;33mPre #:\033[0m       \033[1;37m${pre}\033[0m"
    echo -e "\033[0;33mCleanup:\033[0m     \033[1;37m${cleanup}\033[0m"
    echo -e "\033[0;33mSpace Used:\033[0m  \033[1;37m${space}\033[0m"
    echo ""
    echo -e "\033[0;33mDescription:\033[0m"
    echo -e "\033[1;37m${desc}\033[0m"
}

# Create a new snapshot
create_snapshot() {
    clear
    echo -e "${C_BOLD}${C_CYAN}═══ CREATE NEW SNAPSHOT ═══${C_RESET}\n"
    
    echo -e "${C_YELLOW}Enter snapshot description:${C_RESET}"
    read -r description
    
    if [ -z "$description" ]; then
        show_error "Description cannot be empty"
        return 1
    fi
    
    if confirm_action "Create snapshot with description: '$description'?"; then
        if $SUDO_CMD snapper create --description "$description" 2>/dev/null; then
            show_success "Snapshot created successfully"
        else
            show_error "Failed to create snapshot"
        fi
    fi
}

# Delete a snapshot
delete_snapshot() {
    local snap_num="$1"
    clear
    
    echo -e "${C_BOLD}${C_RED}═══ DELETE SNAPSHOT ═══${C_RESET}\n"
    get_snapshot_preview "$snap_num"
    
    if confirm_action "Delete snapshot #${snap_num}? This action cannot be undone!"; then
        if $SUDO_CMD snapper delete "$snap_num" 2>/dev/null; then
            show_success "Snapshot #${snap_num} deleted successfully"
        else
            show_error "Failed to delete snapshot #${snap_num}"
        fi
    fi
}

# Restore from a snapshot
restore_snapshot() {
    local snap_num="$1"
    clear
    
    echo -e "${C_BOLD}${C_MAGENTA}═══ RESTORE SNAPSHOT ═══${C_RESET}\n"
    get_snapshot_preview "$snap_num"
    
    echo -e "\n${C_RED}${C_BOLD}WARNING: This will restore your system to snapshot #${snap_num}${C_RESET}"
    echo -e "${C_RED}Current files may be modified or deleted!${C_RESET}\n"
    
    if confirm_action "Restore from snapshot #${snap_num}?"; then
        if $SUDO_CMD snapper undochange "${snap_num}..0" 2>/dev/null; then
            show_success "System restored from snapshot #${snap_num}"
        else
            show_error "Failed to restore from snapshot #${snap_num}"
        fi
    fi
}

# Compare snapshots
compare_snapshots() {
    local snap_num="$1"
    $SUDO_CMD snapper status "${snap_num}..0" 2>/dev/null | ${PAGER:-less}
}

# Show snapshot details
show_snapshot_info() {
    local snap_num="$1"
    clear
    
    echo -e "${C_BOLD}${C_CYAN}═══ SNAPSHOT DETAILS ═══${C_RESET}\n"
    get_snapshot_preview "$snap_num"
    
    echo -e "\n${C_DIM}Press any key to continue...${C_RESET}"
    read -rsn1
}

# Modify snapshot description
modify_snapshot() {
    local snap_num="$1"
    clear
    
    echo -e "${C_BOLD}${C_CYAN}═══ MODIFY SNAPSHOT ═══${C_RESET}\n"
    get_snapshot_preview "$snap_num"
    
    local current_desc
    current_desc=$($SUDO_CMD snapper list 2>/dev/null | grep -E "^[[:space:]]*${snap_num}[[:space:]]*│" | awk -F'│' '{print $7}' | xargs)
    
    echo -e "\n${C_YELLOW}Edit description (arrow keys supported):${C_RESET}"
    read -re -i "$current_desc" new_description
    
    if [ -z "$new_description" ]; then
        show_error "Description cannot be empty"
        return 1
    fi
    
    if confirm_action "Update description for snapshot #${snap_num}?"; then
        if $SUDO_CMD snapper modify -d "$new_description" "$snap_num" 2>/dev/null; then
            show_success "Snapshot #${snap_num} description updated"
        else
            show_error "Failed to update snapshot description"
        fi
    fi
}

# ═══════════════════════════════════════════════════════════════════════════
# ACTION MENU
# ═══════════════════════════════════════════════════════════════════════════

# Timeline options menu (merged with limits)
show_timeline_menu() {
    while true; do
        local config enabled
        config=$($SUDO_CMD snapper get-config 2>/dev/null)
        enabled=$(echo "$config" | grep -i 'TIMELINE_CREATE' | awk '{print $NF}')
        get_val() { echo "$config" | grep -i "TIMELINE_LIMIT_${1}" | awk '{print $NF}'; }

        local menu status_line
        if [ "$enabled" = "yes" ]; then
            status_line="Timeline: ENABLED"
            menu=$(printf "Daily     <d>  %s\nWeekly    <e>  %s\nMonthly   <m>  %s\nYearly    <y>  %s\n⏹  Disable Timeline Snapshots\n⬅️  Back to List" \
                "$(get_val DAILY)" "$(get_val WEEKLY)" "$(get_val MONTHLY)" "$(get_val YEARLY)")
        else
            status_line="Timeline: DISABLED"
            menu=$(printf "⏱  Enable Timeline Snapshots\n⬅️  Back to List")
        fi

        local sel
        sel=$(echo "$menu" | \
            fzf --ansi \
                --reverse \
                --height=100% \
                --border=rounded \
                --prompt="Timeline > " \
                --header="$(echo -e "${C_CYAN}${C_BOLD}Timeline Snapshot Settings  [${status_line}]${C_RESET}")" \
                --color="header:cyan:bold,prompt:yellow:bold,pointer:magenta:bold" \
                --pointer="▶" \
                --no-info) || true
        [ -z "$sel" ] && return

        case "$sel" in
            *"Enable"*)
                $SUDO_CMD snapper set-config TIMELINE_CREATE=yes 2>/dev/null
                ;;
            *"Disable"*)
                if confirm_action "Disable timeline snapshots?"; then
                    $SUDO_CMD snapper set-config TIMELINE_CREATE=no 2>/dev/null
                fi
                ;;
            Daily*)
                local cur; cur=$(get_val DAILY)
                echo -e "${C_YELLOW}Daily limit (current: ${cur}):${C_RESET}"
                read -re -i "$cur" val
                [ -n "$val" ] && [ "$val" != "$cur" ] && $SUDO_CMD snapper set-config "TIMELINE_LIMIT_DAILY=${val}" 2>/dev/null
                ;;
            Weekly*)
                local cur; cur=$(get_val WEEKLY)
                echo -e "${C_YELLOW}Weekly limit (current: ${cur}):${C_RESET}"
                read -re -i "$cur" val
                [ -n "$val" ] && [ "$val" != "$cur" ] && $SUDO_CMD snapper set-config "TIMELINE_LIMIT_WEEKLY=${val}" 2>/dev/null
                ;;
            Monthly*)
                local cur; cur=$(get_val MONTHLY)
                echo -e "${C_YELLOW}Monthly limit (current: ${cur}):${C_RESET}"
                read -re -i "$cur" val
                [ -n "$val" ] && [ "$val" != "$cur" ] && $SUDO_CMD snapper set-config "TIMELINE_LIMIT_MONTHLY=${val}" 2>/dev/null
                ;;
            Yearly*)
                local cur; cur=$(get_val YEARLY)
                echo -e "${C_YELLOW}Yearly limit (current: ${cur}):${C_RESET}"
                read -re -i "$cur" val
                [ -n "$val" ] && [ "$val" != "$cur" ] && $SUDO_CMD snapper set-config "TIMELINE_LIMIT_YEARLY=${val}" 2>/dev/null
                ;;
            *"Back"*)
                return
                ;;
        esac
    done
}

# Show action menu for selected snapshot
show_action_menu() {
    local snap_num="$1"
    
    while true; do
        local action
        action=$(echo -e "📋 View Details\n🔍 Compare with Current\n✏️  Modify Description\n♻️  Restore from Snapshot\n🗑️  Delete Snapshot\n⬅️  Back to List" | \
            fzf --ansi \
                --reverse \
                --height=100% \
                --border=rounded \
                --prompt="Select Action for Snapshot #${snap_num} > " \
                --header="$(echo -e "${C_CYAN}${C_BOLD}System Snapshot Manager - Actions${C_RESET}")" \
                --color="header:cyan:bold,prompt:yellow:bold,pointer:magenta:bold" \
                --pointer="▶" \
                --no-info) || true
        
        [ -z "$action" ] && return
        
        case "$action" in
            *"View Details"*)
                show_snapshot_info "$snap_num"
                ;;
            *"Compare"*)
                compare_snapshots "$snap_num"
                ;;
            *"Modify"*)
                modify_snapshot "$snap_num"
                ;;
            *"Restore"*)
                restore_snapshot "$snap_num"
                ;;
            *"Delete"*)
                delete_snapshot "$snap_num"
                return
                ;;
            *"Back"*)
                return
                ;;
        esac
    done
}

# ═══════════════════════════════════════════════════════════════════════════
# MAIN FUNCTION
# ═══════════════════════════════════════════════════════════════════════════

main() {
    # Check for required dependencies
    check_dependencies

    sudo echo " "
        
    # Get the full path to this script
    local SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
    
    # Main loop - show snapshot list
    while true; do
        # Get snapshot list and show in fzf with preview
        local selection
        selection=$(format_snapshot_list | \
            fzf --ansi \
                --reverse \
                --height=100% \
                --border=rounded \
                --prompt="Select Snapshot (ESC to exit) > " \
                --header="$(echo -e "${C_CYAN}${C_BOLD}System Snapshot Manager v${VERSION}${C_RESET}\n${C_DIM}Use ↑↓ to navigate | Enter to select | ESC to exit | Ctrl+N new | Ctrl+O timeline${C_RESET}")" \
                --preview="${SCRIPT_PATH} --preview {1}" \
                --preview-window=right:45%:wrap:border-left \
                --color="header:cyan:bold,prompt:yellow:bold,pointer:magenta:bold,preview-bg:0" \
                --pointer="▶" \
                --bind="ctrl-n:execute(${SCRIPT_PATH} --create)+reload(${SCRIPT_PATH} --list)" \
                --bind="ctrl-o:execute(${SCRIPT_PATH} --timeline)+reload(${SCRIPT_PATH} --list)" \
                --expect=ctrl-c) || true
        
        # Exit if ESC pressed (empty selection)
        [ -z "$selection" ] && break
        
        # Parse selection (skip key if present)
        local key=$(echo "$selection" | head -1)
        local snap_line=$(echo "$selection" | tail -1)
        
        # Handle Ctrl+C (create snapshot) - already handled in bind
        [ "$key" = "ctrl-c" ] && continue
        
        # Extract snapshot number
        local snap_num=$(echo "$snap_line" | awk -F'|' '{print $1}' | xargs)
        
        # Show action menu for selected snapshot
        [ -n "$snap_num" ] && show_action_menu "$snap_num"
    done
    
    clear
    echo -e "${C_GREEN}Thank you for using System Snapshot Manager!${C_RESET}"
}

# ═══════════════════════════════════════════════════════════════════════════
# ENTRY POINT
# ═══════════════════════════════════════════════════════════════════════════

# Handle command-line arguments for fzf callbacks
case "${1:-}" in
    --preview)
        get_snapshot_preview "$2"
        exit 0
        ;;
    --list)
        format_snapshot_list
        exit 0
        ;;
    --create)
        create_snapshot
        exit 0
        ;;
    --timeline)
        show_timeline_menu
        exit 0
        ;;
esac

# Run main function
main "$@"
